# OpenAI
OPENAI_API_KEY=your_openai_key_here

# FHIR Server (vendor-agnostic — works with Epic, Cerner, Oracle Health, etc.)
FHIR_BASE_URL=https://your-fhir-server/fhir/r4

# SMART-on-FHIR Backend Services Auth
SMART_TOKEN_URL=https://your-fhir-server/oauth2/token
SMART_CLIENT_ID=your_client_id
SMART_PRIVATE_KEY_PATH=./keys/private_key.pem
SMART_SCOPE=system/Patient.read system/Observation.read system/Condition.read system/MedicationRequest.read system/Encounter.read system/DiagnosticReport.read

# MCP Server
MCP_SERVER_NAME=ehr-mcp
MCP_SERVER_VERSION=0.1.0
MCP_LOG_LEVEL=INFO
